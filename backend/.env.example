# TinyFish
TINYFISH_API_KEY=your_tinyfish_api_key_here
TINYFISH_RETRIES=0
TINYFISH_BUDGET_ENABLED=true
TINYFISH_BUDGET_FREE_SCORE_CALLS=4
TINYFISH_BUDGET_QUICK_SCAN_CALLS=8
TINYFISH_BUDGET_STANDARD_CALLS=12



# Razorpay (use test keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Server
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173

# Supabase (Auth + user history)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cache TTL in hours
CACHE_TTL_HOURS=24

# Fast mode trims non-critical work in free/quick paths.
FAST_MODE=true
MAX_REPORT_MS=25000
FAST_AGENT_TIMEOUT_MS=16000
BACKGROUND_HYDRATION=false
